{
  "manifest_version": 3,
  "name": "Jatayu Proctor Guard",
  "version": "1.0.0",
  "description": "Anti-cheat guard for Jatayu Proctor assessments. Monitors tab switches, window focus, and DevTools.",
  "permissions": ["tabs", "activeTab", "storage"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://localhost:3000/*", "https://*.jatayuproctor.com/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
